# ── MongoDB ───────────────────────────────────────────────────────────
# Free tier: https://www.mongodb.com/atlas  (512MB free)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/moba_game

# ── JWT ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING

# ── Hathora ───────────────────────────────────────────────────────────
# Sign up free: https://hathora.dev  (no credit card required)
# Dashboard → your app → Settings → App ID
HATHORA_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → your account → Developer Tokens
HATHORA_DEV_TOKEN=YOUR_HATHORA_DEVELOPER_TOKEN

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
